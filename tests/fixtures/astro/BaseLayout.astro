---
import '~/assets/styles/tailwind.css';

import { I18N } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import Metadata from '~/components/common/Metadata.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;

const { language, textDirection } = I18N;

async function resolveMetadata(meta: MetaDataType): Promise<MetaDataType> {
  return {
    ...meta,
    robots: meta?.robots ?? { index: true, follow: true },
  };
}

function buildLangAttr(lang: string, dir: string): Record<string, string> {
  return { lang, dir };
}

const resolvedMeta = await resolveMetadata(metadata);
const langAttrs = buildLangAttr(language, textDirection);
---
<!doctype html>
<html {...langAttrs}>
  <head>
    <CommonMeta />
    <Favicons />
    <Metadata {...resolvedMeta} />
    <ApplyColorMode />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
